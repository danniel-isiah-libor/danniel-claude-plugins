{
  "description": "SDLC team plugin hooks: load repo-local agent memory at session start.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/load-agent-memory.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
